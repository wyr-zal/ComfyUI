出现的区域时，只能在其既有空间、建筑、材质和光照逻辑上进行连续延展，不得引入不相符的新场景元素。\n\n合成与表演：人物在参考图片2的场景中，严格按照参考视频1的完整剧情重新演绎。人物站位、运动轨迹、与环境及道具的接触应服务于原剧情，并符合参考场景的透视和空间结构；人物与环境之间的尺度、透视、光照方向、色温、阴影、反射、遮挡、脚底接触和运动模糊必须自然统一。\n\n硬性禁止：禁止改变剧情、另编情节、遗漏关键动作、改变人物身份、恢复原视频人物、混合两个人物特征、使用原视频背景、将参考背景仅作为风格参考、带入纯色色键背景、新增或删除主要人物、人物复制、身份漂移、脸部闪烁、服装突变、肢体畸形、额外手指、穿模、漂浮、背景跳变、空间结构漂移、镜头无故抖动、乱码、字幕、文字、Logo和水印。","480p","adaptive",10,false,true,false,0,false,false],"color":"#432","bgcolor":"#653"},{"id":205,"type":"SaveVideo","pos":[3865.160646545952,352.08873846087533],"size":[331.328125,604.75],"flags":{},"order":31,"mode":4,"inputs":[{"localized_name":"视频","name":"video","type":"VIDEO","link":151},{"localized_name":"文件名前缀","name":"filename_prefix","type":"STRING","widget":{"name":"filename_prefix"},"link":null},{"localized_name":"格式","name":"format","type":"COMBO","widget":{"name":"format"},"link":null},{"localized_name":"编码器","name":"codec","type":"COMBO","widget":{"name":"codec"},"link":null}],"outputs":[{"localized_name":"video","name":"video","type":"VIDEO","links":null}],"title":"第二步：保存视频（与 Seedance 一起启用）","properties":{},"widgets_values":["video/person_and_background_foreignized","auto","auto"]},{"id":218,"type":"LoadVideo","pos":[-47.88985543319018,721.7218886909218],"size":[420.40625,347.296875],"flags":{},"order":1,"mode":4,"inputs":[{"localized_name":"文件","name":"file","type":"COMBO","widget":{"name":"file"},"link":null},{"localized_name":"选择要上传的文件","name":"upload","type":"IMAGEUPLOAD","widget":{"name":"upload"},"link":null}],"outputs":[{"localized_name":"视频","name":"VIDEO","type":"VIDEO","links":[165]}],"title":"参考视频（视频1：动作 / 背景 / 镜头标准）","properties":{"Node name for S&R":"LoadVideo"},"widgets_values":["202607171109.mp4","image"]},{"id":220,"type":"CompanyImagePromptEnhancer","pos":[438.8487773552452,57.53903106730746],"size":[430,430],"flags":{},"order":8,"mode":0,"inputs":[{"localized_name":"image","name":"image","type":"IMAGE","link":189},{"localized_name":"skill","name":"skill","type":"STRING","widget":{"name":"skill"}