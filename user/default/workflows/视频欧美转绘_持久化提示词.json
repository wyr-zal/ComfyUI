name":"n","type":"INT","widget":{"name":"n"},"link":null},{"localized_name":"seed","name":"seed","type":"INT","widget":{"name":"seed"},"link":null}],"outputs":[{"label":"IMAGE","localized_name":"图像","name":"IMAGE","type":"IMAGE","slot_index":0,"links":[181,199]}],"title":"GPT Image 2：人物转化为欧美外国人","properties":{"Node name for S&R":"CompanyGPTImage2"},"widgets_values":["","gpt-image-2","auto",1024,1024,"opaque","auto",1,2042655797,"fixed"],"color":"#243","bgcolor":"#354"},{"id":228,"type":"PreviewImage","pos":[1816.1692763866517,329.83130081360576],"size":[315,360],"flags":{},"order":27,"mode":0,"inputs":[{"label":"图像","localized_name":"图像","name":"images","type":"IMAGE","link":181}],"outputs":[{"localized_name":"images","name":"images","type":"IMAGE","links":[161]}],"title":"预览：外国人物结果","properties":{"Node name for S&R":"PreviewImage"},"widgets_values":[]},{"id":229,"type":"CompanyImagePromptEnhancer","pos":[2185.374920573813,836.9849587802235],"size":[430,430],"flags":{},"order":22,"mode":0,"inputs":[{"localized_name":"image","name":"image","type":"IMAGE","link":192},{"localized_name":"skill","name":"skill","type":"STRING","widget":{"name":"skill"},"link":null},{"localized_name":"modification_target","name":"modification_target","type":"STRING","widget":{"name":"modification_target"},"link":null},{"localized_name":"model","name":"model","type":"COMBO","widget":{"name":"model"},"link":null},{"localized_name":"temperature","name":"temperature","type":"FLOAT","widget":{"name":"temperature"},"link":null},{"localized_name":"max_tokens","name":"max_tokens","type":"INT","widget":{"name":"max_tokens"},"link":null}],"outputs":[{"label":"优化提示词","localized_name":"优化提示词","name":"优化提示词","type":"STRING","slot_index":0,"links":[197]}],"title":"提示词优化：背景转化为国外场景","properties":{"Node name for S&R":"CompanyImagePromptEnhancer"},"widgets_values":["你是 GPT Image 2 多模态图像编辑提示词专家。先逐张分析用户提供的全部参考图片，识别并在最终提示词中具体描述与修改目标有关的人物身份与外貌、发型、服装、鞋履、配饰、姿态、动作、表情、构图、遮挡、材质、光线、色彩、环境结构和视觉媒介。再结合修改目标，输出一段可直接用于 GPT Image 2 图生图的中文最终提示词。提示词必须针对当前图片定制，不得只复述固定模板；允许在修改目标范围内进行创造性重设计，但必须保持输入图的视觉媒介类型，避免动漫转真人、照片转插画、2D 转 3D 等非目标转换。明确区分必须保留、允许修改和禁止出现的内容，补充边缘处理、空间关系、光影一致性和负面约束。不要解释、不要标题、不要 Markdown，只输出最终提示词。","背景整体欧美化改造：根据参考图片中的实际建筑、街景或室内空间、设施、陈设、道具、材质、光线和色彩关系，将环境创造性重设计为可信且风格统一的欧美国外场景。针对图片中可见的本地化元素逐项提出符合目标地域生活逻辑的建筑语言、公共设施、商铺或室内陈设替代方案；保持镜头、画幅、透视、空间连续性和主要光线关系，画面保持为空景，不出现人物、可辨识文字、乱码、水印或 Logo。","gpt-5.5",0.6,1400,"刷新模型列表"],"color":"#223","bgcolor":"#335"},{"id":230,"type":"CompanyGPTImage2","pos":[2690.3929568991707,779.0850335975235],"size":[520,420],"flags":{},"order":26,"mode":0,"inputs":[{"localized_name":"prompt","name":"prompt","type":"STRING","widget":{"name":"prompt"},"link":185},{"localized_name":"model","name":"model","type":"COMFY_DYNAMICCOMBO_V3","widget":{"name":"model"},"link":null},{"localized_name":"model.size","name":"model.size","type":"COMBO","widget":{"name":"model.size"},"link":null},{"localized_name":"model.custom_width","name":"model.custom_width","type":"INT","widget":{"name":"model.custom_width"},"link":null},{"localized_name":"model.custom_height","name":"model.custom_height","type":"INT","widget":{"name":"model.custom_height"},"link":null},{"localized_name":"model.background","name":"model.background","type":"COMBO","widget":{"name":"model.background"},"link":null},{"localized_name":"model.quality","name":"model.quality","type":"COMBO","widget":{"name":"model.quality"},"link":null},{"label":"image_1","localized_name":"model.images.image_1","name":"model.images.image_1","shape":7,"type":"IMAGE","link":null},{"label":"mask","localized_name":"model.mask","name":"model.mask","shape":7,"type":"MASK","link":null},{"localized_name":"n","name":"n","type":"INT","widget":{"name":"n"},"link":null},{"localized_name":"seed","name":"seed","type":"INT","widget":{"name":"seed"},"link":null}],"outputs":[{"label":"IMAGE","localized_name":"图像","name":"IMAGE","type":"IMAGE","slot_index":0,"links":[187,200]}],"title":"GPT Image 2：背景转化为欧美国外场景","properties":{"Node name for S&R":"CompanyGPTImage2"},"widgets_values":["","gpt-image-2","auto",1024,1024,"opaque","auto",1,194673924,"fixed"],"color":"#243","bgcolor":"#354"},{"id":231,"type":"PreviewImage","pos":[1823.516552306489,992.1639187853201],"size":[315,360],"flags":{},"order":29,"mode":0,"inputs":[{"label":"图像","localized_name":"图像","name":"images","type":"IMAGE","link":187}],"outputs":[{"localized_name":"images","name":"images","type":"IMAGE","links":[188]}],"title":"预览：国外背景结果","properties":{"Node name for S&R":"PreviewImage"},"widgets_values":[]},{"id":233,"type":"CompanyPersistentPromptDisplay","pos":[440,535],"size":[390,220],"flags":{},"order":13,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","link":194}],"outputs":[{"label":"提示词","localized_name":"提示词","name":"提示词","type":"STRING","slot_index":0,"links":[176]}],"title":"持久化优化提示词：人物提取","properties":{"Node name for S&R":"CompanyPersistentPromptDisplay","last_prompt_text":"将参考图中右侧的主要人物单独提取并重设计成完整单人角色：保持原图的电影级写实奇幻武士视觉媒介与动态运动模糊质感，不要转成插画、动漫或3D玩具。必须保留人物辨识特征：戴一顶宽大的圆形斗笠/阵笠，帽檐上有复杂金色浮雕纹样与破损流苏边；脸部大部分被帽檐阴影遮挡，保持神秘感；身穿深酒红、黑色为主的武士披挂与宽袖衣袍，带金属护肩、护臂、腰带和层叠布甲；腰间保留一把蓝黑色刀鞘的佩刀；整体为低身前冲的战斗武士气质。删除原来的雪山、天空、草丛、烟雾、远处小动物、光束、顶部绿色条、底部黑边和右下角小头像等所有场景、道具和其他人物，只保留这一个武士。将人物从头到脚完整呈现并居中放置在均匀、无纹理、无阴影渐变的高饱和纯色色键背景上，背景选择纯绿色 chroma key green（#00FF00），因为人物主体为黑、深红、金属金和少量蓝黑刀鞘，与绿色反差最强且不污染边缘。允许对造型进行创造性优化：把原图中被草丛和画面裁切遮挡的下半身合理补全为完整武士袴裤、护膝、绑腿和深色战靴/草鞋，材质与上身盔甲一致；将原本模糊的前冲动作优化为更清晰的全身动态姿态，一腿前踏、一腿后蹬，身体前倾，右臂向前横向挥刀或拔刀，左手稳定腰间刀鞘，衣袖、腰带和斗笠流苏随动作向后飘动。保留适度电影运动感，但人物轮廓必须清楚可抠像，头顶斗笠流苏、衣摆、袖口、腰带、刀柄、刀鞘、靴底等复杂边缘要干净锐利，无绿色溢色、无半透明残留、无背景草叶粘连。光影保持原图冷色电影光与金属高光：从左前方来一束柔冷主光，金色纹样和盔甲边缘有细腻反光，阴影方向统一；不要添加地面、投影、雾、雪、山、草、云、额外武器、额外人物、文字、水印、边框或任何非纯色背景元素。"},"widgets_values":["将参考图中右侧的主要人物单独提取并重设计成完整单人角色：保持原图的电影级写实奇幻武士视觉媒介与动态运动模糊质感，不要转成插画、动漫或3D玩具。必须保留人物辨识特征：戴一顶宽大的圆形斗笠/阵笠，帽檐上有复杂金色浮雕纹样与破损流苏边；脸部大部分被帽檐阴影遮挡，保持神秘感；身穿深酒红、黑色为主的武士披挂与宽袖衣袍，带金属护肩、护臂、腰带和层叠布甲；腰间保留一把蓝黑色刀鞘的佩刀；整体为低身前冲的战斗武士气质。删除原来的雪山、天空、草丛、烟雾、远处小动物、光束、顶部绿色条、底部黑边和右下角小头像等所有场景、道具和其他人物，只保留这一个武士。将人物从头到脚完整呈现并居中放置在均匀、无纹理、无阴影渐变的高饱和纯色色键背景上，背景选择纯绿色 chroma key green（#00FF00），因为人物主体为黑、深红、金属金和少量蓝黑刀鞘，与绿色反差最强且不污染边缘。允许对造型进行创造性优化：把原图中被草丛和画面裁切遮挡的下半身合理补全为完整武士袴裤、护膝、绑腿和深色战靴/草鞋，材质与上身盔甲一致；将原本模糊的前冲动作优化为更清晰的全身动态姿态，一腿前踏、一腿后蹬，身体前倾，右臂向前横向挥刀或拔刀，左手稳定腰间刀鞘，衣袖、腰带和斗笠流苏随动作向后飘动。保留适度电影运动感，但人物轮廓必须清楚可抠像，头顶斗笠流苏、衣摆、袖口、腰带、刀柄、刀鞘、靴底等复杂边缘要干净锐利，无绿色溢色、无半透明残留、无背景草叶粘连。光影保持原图冷色电影光与金属高光：从左前方来一束柔冷主光，金色纹样和盔甲边缘有细腻反光，阴影方向统一；不要添加地面、投影、雾、雪、山、草、云、额外武器、额外人物、文字、水印、边框或任何非纯色背景元素。"]},{"id":234,"type":"CompanyPersistentPromptDisplay","pos":[400,1250],"size":[390,220],"flags":{},"order":14,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","link":195}],"outputs":[{"label":"提示词","localized_name":"提示词","name":"提示词","type":"STRING","slot_index":0,"links":[182]}],"title":"持久化优化提示词：背景提取","properties":{"Node name for S&R":"CompanyPersistentPromptDisplay","last_prompt_text":"将参考图重绘为干净完整的纯背景画面，保持原图的横向超宽画幅与半写实动画电影感数字绘景风格。必须保留并延展原画面中的自然环境：低机位远景透视，前景是被风吹动的深绿色草坡与白色芒草、柔焦运动模糊的草叶；中远景有云海与薄雾；右侧远处是一座覆雪的富士山式火山轮廓；天空为黎明/黄昏的柔和粉白色天光，周围有蓝灰色厚云，整体冷蓝、雾白、淡粉的色彩氛围，光线从地平线附近柔和散射，山体与草地受同一方向的自然天光照明。\n\n彻底移除画面中所有人物与人物相关元素：中央偏右戴斗笠的黑色武士/旅人剪影、斗笠、身体、刀、披风、人物阴影与遮挡；右下角Q版女孩头像；所有视频播放器界面、黑色上下大边框、绿色进度线、播放按钮、时间文字、音量/全屏/菜单图标、底部进度条、任何文字、水印或Logo。被人物和界面遮挡的区域要按原有透视、材质和光照逻辑自然补全：中央人物位置补成连续的雾气、草坡和远处云海，不留下人形轮廓；右下角补成与周围一致的暗色草地与柔焦芒草；顶部和底部黑色区域改为自然延展的天空、云层、远山雾气与前景草地，使整张图成为无界面、无边框、空间连续的完整风景背景。\n\n允许适度整理和重设计不协调细节：增强天空云层的层次、让雪山轮廓更自然但不改变其右侧位置与远景尺度；前景草叶可保持风吹模糊和景深虚化，边缘过渡柔和，不出现硬切线、涂抹痕迹或重复纹理。禁止出现任何人物、动物、人形剪影、武器、建筑、文字、UI控件、Logo、水印、黑边、纯色遮挡条。保持画面为二维数字绘景/动画背景，不要转为真人照片、3D渲染或卡通贴纸风。"},"widgets_values":["将参考图重绘为干净完整的纯背景画面，保持原图的横向超宽画幅与半写实动画电影感数字绘景风格。必须保留并延展原画面中的自然环境：低机位远景透视，前景是被风吹动的深绿色草坡与白色芒草、柔焦运动模糊的草叶；中远景有云海与薄雾；右侧远处是一座覆雪的富士山式火山轮廓；天空为黎明/黄昏的柔和粉白色天光，周围有蓝灰色厚云，整体冷蓝、雾白、淡粉的色彩氛围，光线从地平线附近柔和散射，山体与草地受同一方向的自然天光照明。\n\n彻底移除画面中所有人物与人物相关元素：中央偏右戴斗笠的黑色武士/旅人剪影、斗笠、身体、刀、披风、人物阴影与遮挡；右下角Q版女孩头像；所有视频播放器界面、黑色上下大边框、绿色进度线、播放按钮、时间文字、音量/全屏/菜单图标、底部进度条、任何文字、水印或Logo。被人物和界面遮挡的区域要按原有透视、材质和光照逻辑自然补全：中央人物位置补成连续的雾气、草坡和远处云海，不留下人形轮廓；右下角补成与周围一致的暗色草地与柔焦芒草；顶部和底部黑色区域改为自然延展的天空、云层、远山雾气与前景草地，使整张图成为无界面、无边框、空间连续的完整风景背景。\n\n允许适度整理和重设计不协调细节：增强天空云层的层次、让雪山轮廓更自然但不改变其右侧位置与远景尺度；前景草叶可保持风吹模糊和景深虚化，边缘过渡柔和，不出现硬切线、涂抹痕迹或重复纹理。禁止出现任何人物、动物、人形剪影、武器、建筑、文字、UI控件、Logo、水印、黑边、纯色遮挡条。保持画面为二维数字绘景/动画背景，不要转为真人照片、3D渲染或卡通贴纸风。"]},{"id":235,"type":"CompanyPersistentPromptDisplay","pos":[2126.3829802473447,564.5866222211131],"size":[390,220],"flags":{},"order":23,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","link":196}],"outputs":[{"label":"提示词","localized_name":"提示词","name":"提示词","type":"STRING","slot_index":0,"links":[179]}],"title":"持久化优化提示词：人物欧美化","properties":{"Node name for S&R":"CompanyPersistentPromptDisplay","last_prompt_text":"将参考图中的单人角色完整重设计为当代欧美审美的西方男性暗黑奇幻剑客，保持原图的高细节CG游戏角色渲染质感、全身构图、纯亮绿色色键背景和动态前冲姿态。必须保留：完整单人、成年男性、运动中的俯身冲刺/跃步动作、左臂向画面左侧伸出持细长剑的方向感、右手靠近腰侧武器的防御姿态、衣摆和披风随动作向后飘动、中心偏右的全身构图、强烈的金属与皮革材质细节、干净抠像边缘、无地面场景的纯绿色背景。\n\n将人物整体欧美化，而不是只换脸：面部改为欧美男性特征，轮廓硬朗、鼻梁高、眉骨清晰、浅色或灰蓝眼睛、短胡茬，表情冷静自信、略带战斗专注感；肤色自然欧美浅肤或小麦肤色。发型改为深金棕或深棕色中长发，从帽檐下自然散出，带轻微凌乱的动作感，可有少量发束被风吹起。妆容/面部处理为自然写实的战斗风格，轻微烟熏阴影、汗光和尘痕，不要东方戏曲感或面具感。\n\n服装完整改为欧美暗黑奇幻/西方游侠剑客造型：用宽檐黑色皮革骑士帽或西部哥特风帽替代原来的东方斗笠，帽面可有低调巴洛克金属浮雕与皮革压纹，但不要东方花纹；上身改为剪裁合身的黑色皮革长风衣、深酒红内衬、暗色马甲或高领衬衫，肩部为西式哥特护肩或轻量板甲，装饰为欧式卷草、狮鹫、十字星形或巴洛克纹样；腰部用多层皮带、银色扣件、弹药包/剑鞘挂具替代原来的布腰封；下身改为修身战斗裤与分层皮革护腿，膝盖保留圆形金属护具但改为欧式浮雕纹章。鞋履改为黑色高筒皮革战斗靴/骑士靴，厚底、金属扣带、包覆脚踝，符合欧美奇幻服装比例，不要分趾鞋、绑腿草鞋或忍者鞋。\n\n武器与配饰允许欧美化调整：左手长剑改为细长西式刺剑、长剑或黑色钢制决斗剑，剑身仍沿画面左侧伸出，保持锋利透视；腰侧可保留第二把短剑或匕首，但改为西式皮革剑鞘与金属护手。胸前吊坠改为银色或暗金色欧式护符/怀表式圆形徽章，手套改为黑色皮革战斗手套。整体配色保持深黑、酒红、暗银、旧金的高级暗色调，材质包含磨损皮革、哑光布料、冷金属、轻微划痕和边缘磨损。\n\n允许适度优化姿态：让角色动作更松弛、自信、具有欧美动作游戏主角气质，重心稳定，肩颈自然，帽檐不要完全遮住脸，至少露出部分眼睛、鼻梁和胡茬；衣摆、发丝、皮带和披风的飘动方向要与原图冲刺方向一致。保持原图光影逻辑：人物主体有强烈侧向高光和深阴影，金属边缘有冷亮反光，绿色背景不投射到人物皮肤和服装上，避免绿边污染；重绘人物边缘，使衣摆、剑尖、发丝和帽檐轮廓清晰自然，无遮挡错误、无断肢、无多余手指。\n\n禁止出现：亚洲武士、忍者、斗笠、和服、袴裤、布腰封、东方刀镡、汉字/日文/中文符号、东方龙纹、分趾鞋、原本本土服装残留；禁止只替换脸而保留原造型；禁止新增其他人物、背景场景、地面、建筑、烟雾遮挡、文字、水印、logo；禁止动漫化、卡通化、油画化、真人照片化，必须保持原图同类高精度3D/CG角色渲染视觉媒介。"},"widgets_values":["将参考图中的单人角色完整重设计为当代欧美审美的西方男性暗黑奇幻剑客，保持原图的高细节CG游戏角色渲染质感、全身构图、纯亮绿色色键背景和动态前冲姿态。必须保留：完整单人、成年男性、运动中的俯身冲刺/跃步动作、左臂向画面左侧伸出持细长剑的方向感、右手靠近腰侧武器的防御姿态、衣摆和披风随动作向后飘动、中心偏右的全身构图、强烈的金属与皮革材质细节、干净抠像边缘、无地面场景的纯绿色背景。\n\n将人物整体欧美化，而不是只换脸：面部改为欧美男性特征，轮廓硬朗、鼻梁高、眉骨清晰、浅色或灰蓝眼睛、短胡茬，表情冷静自信、略带战斗专注感；肤色自然欧美浅肤或小麦肤色。发型改为深金棕或深棕色中长发，从帽檐下自然散出，带轻微凌乱的动作感，可有少量发束被风吹起。妆容/面部处理为自然写实的战斗风格，轻微烟熏阴影、汗光和尘痕，不要东方戏曲感或面具感。\n\n服装完整改为欧美暗黑奇幻/西方游侠剑客造型：用宽檐黑色皮革骑士帽或西部哥特风帽替代原来的东方斗笠，帽面可有低调巴洛克金属浮雕与皮革压纹，但不要东方花纹；上身改为剪裁合身的黑色皮革长风衣、深酒红内衬、暗色马甲或高领衬衫，肩部为西式哥特护肩或轻量板甲，装饰为欧式卷草、狮鹫、十字星形或巴洛克纹样；腰部用多层皮带、银色扣件、弹药包/剑鞘挂具替代原来的布腰封；下身改为修身战斗裤与分层皮革护腿，膝盖保留圆形金属护具但改为欧式浮雕纹章。鞋履改为黑色高筒皮革战斗靴/骑士靴，厚底、金属扣带、包覆脚踝，符合欧美奇幻服装比例，不要分趾鞋、绑腿草鞋或忍者鞋。\n\n武器与配饰允许欧美化调整：左手长剑改为细长西式刺剑、长剑或黑色钢制决斗剑，剑身仍沿画面左侧伸出，保持锋利透视；腰侧可保留第二把短剑或匕首，但改为西式皮革剑鞘与金属护手。胸前吊坠改为银色或暗金色欧式护符/怀表式圆形徽章，手套改为黑色皮革战斗手套。整体配色保持深黑、酒红、暗银、旧金的高级暗色调，材质包含磨损皮革、哑光布料、冷金属、轻微划痕和边缘磨损。\n\n允许适度优化姿态：让角色动作更松弛、自信、具有欧美动作游戏主角气质，重心稳定，肩颈自然，帽檐不要完全遮住脸，至少露出部分眼睛、鼻梁和胡茬；衣摆、发丝、皮带和披风的飘动方向要与原图冲刺方向一致。保持原图光影逻辑：人物主体有强烈侧向高光和深阴影，金属边缘有冷亮反光，绿色背景不投射到人物皮肤和服装上，避免绿边污染；重绘人物边缘，使衣摆、剑尖、发丝和帽檐轮廓清晰自然，无遮挡错误、无断肢、无多余手指。\n\n禁止出现：亚洲武士、忍者、斗笠、和服、袴裤、布腰封、东方刀镡、汉字/日文/中文符号、东方龙纹、分趾鞋、原本本土服装残留；禁止只替换脸而保留原造型；禁止新增其他人物、背景场景、地面、建筑、烟雾遮挡、文字、水印、logo；禁止动漫化、卡通化、油画化、真人照片化，必须保持原图同类高精度3D/CG角色渲染视觉媒介。"]},{"id":236,"type":"CompanyPersistentPromptDisplay","pos":[2201,1354.0523972479666],"size":[390,220],"flags":{},"order":24,"mode":0,"inputs":[{"localized_name":"text","name":"text","type":"STRING","link":197}],"outputs":[{"label":"提示词","localized_name":"提示词","name":"提示词","type":"STRING","slot_index":0,"links":[185]}],"title":"持久化优化提示词：背景欧美化","properties":{"Node name for S&R":"CompanyPersistentPromptDisplay","last_prompt_text":"将当前空旷山景整体重设计为可信的北美太平洋西北地区高山自然景观，保持原图写实、电影感、超宽画幅、低机位广角透视和空间连续性：前景仍是从左下延伸到右下的斜坡草甸，草叶贴近镜头、部分虚化，形成原图的遮挡层次；远景仍在画面右侧保留一座大型雪覆锥形山体，云海横贯中景，天空为傍晚蓝紫色厚云与粉橙色余晖。\n\n必须保留：原始镜头位置、横向全景构图、右侧雪山主体的位置和体量、左前景高草占据画面下半部的遮挡关系、云海高度、日落逆光方向、冷蓝与粉紫暖光交织的色彩关系、空气透视、草叶边缘的柔和景深和风吹动感。  \n允许修改：将具有日本富士山联想的山体和本地化植被替换为北美风格场景——把远处山峰改造成类似美国华盛顿州 Mount Rainier / Cascade Range 的雪覆火山，山腰增加更自然的岩脊、冰川沟槽、深色针叶林带和不规则积雪纹理，避免过于完美对称的富士山轮廓；把前景疑似东亚芒草替换为北美高山草甸植物，如细长的野黑麦、羽芒草、莎草、少量低矮野花和潮湿草甸植被，草穗保留银白反光但形态更自然多样；中景云海下方可隐约加入深蓝色冷杉林、远处山脊和冰川谷地的层次。  \n本地化元素替代方案：不要出现任何日式山名、神社、鸟居、日式屋顶、稻田、竹林、东亚道路设施或标识；若需要体现地域逻辑，只通过北美自然地貌表达，例如冰川侵蚀的山谷、针叶林带、火山岩坡、国家公园式未开发荒野感，不添加建筑、商铺、路牌、围栏或人工设施。  \n光影与材质：保持夕阳从左侧云层后方透出，粉橙色光照亮云边和草穗，右侧雪山受冷蓝阴影覆盖但峰顶有淡淡暖光；草叶表面带露水和半透明边缘高光，云层蓬松厚重，雪面细节清晰但不过度锐化，整体色调统一为冷蓝、青绿、银白与淡粉橙。  \n边缘处理：前景草叶与天空、云海交界处要自然融合，无抠图痕迹；新增山体、针叶林和云层需符合原有透视和大气距离，远处细节随雾气降低对比度。  \n禁止出现：人物、动物、车辆、建筑、文字、乱码、Logo、水印、路牌、人工栏杆、城市灯光、动漫化、插画化、3D玩具感、过度HDR、明显重复的草叶纹理、富士山式过度对称轮廓、任何可辨识日式或东亚文化符号。保持画面为空景、自然、真实、统一的欧美北美高山日落风光。"},"widgets_values":["将当前空旷山景整体重设计为可信的北美太平洋西北地区高山自然景观，保持原图写实、电影感、超宽画幅、低机位广角透视和空间连续性：前景仍是从左下延伸到右下的斜坡草甸，草叶贴近镜头、部分虚化，形成原图的遮挡层次；远景仍在画面右侧保留一座大型雪覆锥形山体，云海横贯中景，天空为傍晚蓝紫色厚云与粉橙色余晖。\n\n必须保留：原始镜头位置、横向全景构图、右侧雪山主体的位置和体量、左前景高草占据画面下半部的遮挡关系、云海高度、日落逆光方向、冷蓝与粉紫暖光交织的色彩关系、空气透视、草叶边缘的柔和景深和风吹动感。  \n允许修改：将具有日本富士山联想的山体和本地化植被替换为北美风格场景——把远处山峰改造成类似美国华盛顿州 Mount Rainier / Cascade Range 的雪覆火山，山腰增加更自然的岩脊、冰川沟槽、深色针叶林带和不规则积雪纹理，避免过于完美对称的富士山轮廓；把前景疑似东亚芒草替换为北美高山草甸植物，如细长的野黑麦、羽芒草、莎草、少量低矮野花和潮湿草甸植被，草穗保留银白反光但形态更自然多样；中景云海下方可隐约加入深蓝色冷杉林、远处山脊和冰川谷地的层次。  \n本地化元素替代方案：不要出现任何日式山名、神社、鸟居、日式屋顶、稻田、竹林、东亚道路设施或标识；若需要体现地域逻辑，只通过北美自然地貌表达，例如冰川侵蚀的山谷、针叶林带、火山岩坡、国家公园式未开发荒野感，不添加建筑、商铺、路牌、围栏或人工设施。  \n光影与材质：保持夕阳从左侧云层后方透出，粉橙色光照亮云边和草穗，右侧雪山受冷蓝阴影覆盖但峰顶有淡淡暖光；草叶表面带露水和半透明边缘高光，云层蓬松厚重，雪面细节清晰但不过度锐化，整体色调统一为冷蓝、青绿、银白与淡粉橙。  \n边缘处理：前景草叶与天空、云海交界处要自然融合，无抠图痕迹；新增山体、针叶林和云层需符合原有透视和大气距离，远处细节随雾气降低对比度。  \n禁止出现：人物、动物、车辆、建筑、文字、乱码、Logo、水印、路牌、人工栏杆、城市灯光、动漫化、插画化、3D玩具感、过度HDR、明显重复的草叶纹理、富士山式过度对称轮廓、任何可辨识日式或东亚文化符号。保持画面为空景、自然、真实、统一的欧美北美高山日落风光。"]},{"id":237,"type":"LoadImage","pos":[-15.0416122829904,319.8792824540758],"size":[315,344],"flags":{},"order":2,"mode":0,"inputs":[{"localized_name":"图像","name":"image","type":"COMBO","widget":{"name":"image"},"link":null},{"localized_name":"选择文件上传","name":"upload","type":"IMAGEUPLOAD","widget":{"name":"upload"},"link":null}],"outputs":[{"label":"图像","localized_name":"图像","name":"IMAGE","type":"IMAGE","slot_index":0,"links":[198]},{"label":"遮罩","localized_name":"遮罩","name":"MASK","type":"MASK","links":null}],"title":"输入图片：待拆分和转换的人物场景图","properties":{"Node name for S&R":"LoadImage"},"widgets_values":["Snipaste_2026-07-17_11-12-43.png","image"]},{"id":238,"type":"SaveImageAdvanced","pos":[3375.8563697615555,-143.0055342725958],"size":[306.984375,376],"flags